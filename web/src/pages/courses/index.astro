---
export const prerender = false; // SSR 동작을 위해 false로 설정

import DefaultLayout from "@/layouts/DefaultLayout.astro";
import SearchBar from "@/components/client/SearchBar";
import CourseSearchList from "@/components/client/CourseSearchList";
---

<DefaultLayout>
	<div class="text-center mb-6">
		<h1 class="text-3xl font-bold">Trailine 코스 찾기</h1>
		<p class="text-base-content/60 mt-2">나에게 맞는 트레킹 코스를 검색해 보세요</p>
	</div>
	<div class="flex justify-center"><SearchBar client:load /></div>
	<div class="flex justify-center"><CourseSearchList client:load /></div>
</DefaultLayout>